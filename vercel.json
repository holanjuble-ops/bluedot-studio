{
  "buildCommand": "npm install && node build.js",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/column/%EC%B9%BC%EB%9F%BC-%EC%83%81%EC%84%B8.html",
      "destination": "/column/column-detail.html",
      "permanent": true
    },
    {
      "source": "/column/%EC%B9%BC%EB%9F%BC%20%EC%83%81%EC%84%B8.html",
      "destination": "/column/column-detail.html",
      "permanent": true
    },
    {
      "source": "/column/%EC%B9%BC%EB%9F%BC.html",
      "destination": "/column/column.html",
      "permanent": true
    }
  ]
}
